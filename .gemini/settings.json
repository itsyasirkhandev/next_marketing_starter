{
  "general": {
    "plan": {
      "directory": ".gemini/plans"
    }
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "track-modified-file",
            "type": "command",
            "command": "node .gemini/hooks/track-file.js",
            "description": "Track AI-modified files"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "lint-and-typecheck",
            "type": "command",
            "command": "node .gemini/hooks/run-checks.js",
            "description": "Run linting and typechecking",
            "timeout": 300000
          }
        ]
      }
    ]
  }
}
